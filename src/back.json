":"header","required":false,"schema":{"type":"string","description":"Bearer <token> del login de admin.","title":"Authorization"},"description":"Bearer <token> del login de admin."}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}}},"components":{"schemas":{"AlertaFamiliar":{"properties":{"person_id":{"type":"string","title":"Person Id"},"familiar_nombre":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Familiar Nombre"},"familiar_telefono":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Familiar Telefono"},"image_url":{"type":"string","title":"Image Url"},"coincidencia":{"type":"integer","title":"Coincidencia"},"confianza":{"type":"string","title":"Confianza"}},"type":"object","required":["person_id","image_url","coincidencia","confianza"],"title":"AlertaFamiliar","description":"Aviso cuando un RESCATISTA registra a alguien que un familiar ya buscaba."},"Body_buscar_admin_buscar_post":{"properties":{"file":{"type":"string","contentMediaType":"application/octet-stream","title":"File"},"limite":{"type":"integer","title":"Limite","default":25},"estado":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Estado","description":"Filtrar por 'buscada' o 'encontrada' (vacío = todas)."}},"type":"object","required":["file"],"title":"Body_buscar_admin_buscar_post"},"Body_registrar_busqueda_buscados_post":{"properties":{"files":{"items":{"type":"string","contentMediaType":"application/octet-stream"},"type":"array","title":"Files","description":"Foto(s) del rostro de la persona buscada (obligatorio)."},"nombre":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Nombre"},"apellido":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Apellido"},"edad":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Edad"},"doc_tipo":{"anyOf":[{"type":"string"},{"type":"null"}],"title":